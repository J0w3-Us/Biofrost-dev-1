part of 'loggin_form_cubit.dart';

class LoginFormState {
  final bool isRememberChecked;

  const LoginFormState({this.isRememberChecked = false});

  LoginFormState copyWith({bool? isRememberChecked}) {
    return LoginFormState(
      isRememberChecked: isRememberChecked ?? this.isRememberChecked,
    );
  }
}
